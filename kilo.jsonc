{
  "mcp": {
    "obsidian-cli": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "github:Storks/obsidian-mcp"
      ],
      "enabled": true,
      "environment": {}
    },
    "wdio-mcp": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@wdio/mcp"
      ],
      "enabled": true,
      "environment": {}
    }
  },
  "permission": {}
}
