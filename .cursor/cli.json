{
  "version": 1,
  "editor": {
    "vimMode": false
  },
  "permissions": {
    "allow": [
      "Shell(* && echo \"EXIT:$?\")",
      "Shell(* && echo EXIT:*)",
      "Shell(* &&echo EXIT:*)",
      "Shell(*; echo \"EXIT:$?\")",
      "Shell(*; echo EXIT:*)",
      "Shell(*;echo EXIT:*)",
      "Shell(bun run build)",
      "Shell(bun run test:bdd)",
      "Shell(bun run test:bdd:desktop)",
      "Shell(bun run test:bdd:mobile)",
      "Shell(bun run test:bdd:scroll)",
      "Shell(bun run typecheck)",
      "Shell(echo EXIT:*)",
      "Shell(rtk bun run build)",
      "Shell(rtk bun run test:bdd)",
      "Shell(rtk bun run test:bdd:desktop)",
      "Shell(rtk bun run test:bdd:mobile)",
      "Shell(rtk bun run test:bdd:scroll)",
      "Shell(rtk bun run typecheck)"
    ]
  }
}
